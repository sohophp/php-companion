{
  "name": "php-companion-recommended-pack",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.4.0",
  "publisher": "sohophp",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sohophp/php-companion.git"
  },
  "homepage": "https://github.com/sohophp/php-companion/tree/main/packages/php-companion-recommended-pack#readme",
  "bugs": {
    "url": "https://github.com/sohophp/php-companion/issues"
  },
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#100B3B",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Extension Packs"
  ],
  "keywords": [
    "php",
    "phpstorm",
    "extension pack",
    "composer",
    "intelephense",
    "twig"
  ],
  "files": [
    "README.md",
    "LICENSE",
    "resources/icon.png",
    "package.nls.json",
    "package.nls.zh-cn.json"
  ],
  "scripts": {
    "package": "vsce package"
  },
  "contributes": {
    "configurationDefaults": {
      "phpCompanion.indexing.mode": "onDemand",
      "phpCompanion.imports.onPaste": "prompt",
      "phpCompanion.experimental.refactoring": false,
      "phpCompanion.rename.enabled": true,
      "[php]": {
        "editor.defaultFormatter": "junstyle.php-cs-fixer"
      }
    }
  },
  "extensionPack": [
    "sohophp.php-companion",
    "sohophp.twig-plus",
    "bmewburn.vscode-intelephense-client",
    "xdebug.php-debug",
    "recca0120.vscode-phpunit",
    "junstyle.php-cs-fixer",
    "EditorConfig.EditorConfig"
  ]
}
