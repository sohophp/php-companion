{
  "name": "php-companion",
  "displayName": "PHP Companion (Paused)",
  "description": "Inactive placeholder release while PHP Companion is being redesigned.",
  "version": "0.1.3",
  "publisher": "sohophp",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sohophp/php-companion.git"
  },
  "homepage": "https://github.com/sohophp/php-companion#readme",
  "bugs": {
    "url": "https://github.com/sohophp/php-companion/issues"
  },
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#07183F",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "php",
    "phpstorm",
    "refactor",
    "composer",
    "psr-4"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "files": [
    "dist/extension.js",
    "resources/icon.png",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "node esbuild.mjs --production",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test scripts esbuild.mjs vitest.config.ts vitest.integration.config.ts",
    "test": "vitest run",
    "test:integration:php": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "test:extension": "pnpm build && xvfb-run -a node ./dist-test/runTest.js",
    "test:extension:intelephense": "PHP_COMPANION_TEST_WITH_INTELEPHENSE=1 pnpm test:extension",
    "pretest:extension": "tsc -p test/extension/tsconfig.json",
    "package": "pnpm build && vsce package --no-dependencies",
    "package:open-source-pack": "pnpm --dir packages/php-companion-extension-pack package",
    "package:recommended-pack": "pnpm --dir packages/php-companion-recommended-pack package",
    "package:all": "pnpm package && pnpm package:open-source-pack && pnpm package:recommended-pack",
    "verify:vsix": "node scripts/verify-vsix.mjs",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm package:all && pnpm verify:vsix"
  },
  "extensionDependencies": [],
  "extensionPack": [],
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.15.0",
    "@types/semver": "^7.7.1",
    "@types/vscode": "^1.100.0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "@types/yauzl": "^2.10.3",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10",
    "yauzl": "^3.2.0",
    "minimatch": "^10.2.5",
    "semver": "^7.8.5",
    "tree-sitter-php": "^0.24.2",
    "web-tree-sitter": "^0.26.11"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26"
}
